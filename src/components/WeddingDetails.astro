---
const details = [
  {
    icon: "⛪",
    title: "Ceremonia",
    time: "5:00 PM",
    location: "Capilla del Jardín",
    address: "Hacienda Los Olivos, Guadalajara",
    note: "El amor nos une en este momento sagrado",
  },
  {
    icon: "🥂",
    title: "Recepción",
    time: "7:00 PM",
    location: "Jardín Principal",
    address: "Hacienda Los Olivos, Guadalajara",
    note: "Cena, brindis y fiesta bajo las estrellas",
  },
  {
    icon: "👔",
    title: "Código de vestimenta",
    time: "",
    location: "Formal / Cocktail",
    address: "",
    note: "Celebra con elegancia y comodidad",
  },
];
---

<section class="py-24 bg-forest relative overflow-hidden">
  <!-- Dot pattern overlay -->
  <div
    class="absolute inset-0 opacity-5 pointer-events-none"
    style="background-image: radial-gradient(circle at 2px 2px, hsl(var(--gold-light)) 1px, transparent 0); background-size: 40px 40px;"
  />

  <div class="relative z-10 max-w-5xl mx-auto px-6">

    <div class="text-center mb-16 reveal">
      <p class="font-sans text-xs tracking-[0.35em] uppercase text-gold-light mb-4">
        Los detalles
      </p>
      <h2 class="font-serif text-4xl md:text-5xl font-light text-primary-foreground">
        Información del Evento
      </h2>
      <div class="flex items-center justify-center gap-4 mt-6 max-w-xs mx-auto">
        <div class="flex-1 h-px bg-linear-to-r from-transparent to-gold-light/40" />
        <span class="text-gold-light text-sm">❖</span>
        <div class="flex-1 h-px bg-linear-to-l from-transparent to-gold-light/40" />
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {details.map((detail, idx) => (
        <div
          class="reveal text-center p-8 border border-gold-light/20 backdrop-blur-sm bg-primary/10 rounded-sm hover:-translate-y-1 transition-transform duration-300"
          style={`transition-delay: ${idx * 0.2}s`}
        >
          <div class="text-4xl mb-4">{detail.icon}</div>
          <h3 class="font-serif text-2xl text-primary-foreground mb-2">{detail.title}</h3>
          {detail.time && (
            <p class="font-sans text-lg text-gold-light font-light mb-2">{detail.time}</p>
          )}
          <p class="font-sans text-sm text-primary-foreground/80 mb-1">{detail.location}</p>
          {detail.address && (
            <p class="font-sans text-xs text-primary-foreground/50 mb-4">{detail.address}</p>
          )}
          <p class="font-serif text-sm italic text-gold-light/70">{detail.note}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-20 reveal" style="transition-delay: 0.5s">
      <blockquote class="font-serif text-xl md:text-2xl italic text-primary-foreground/80 max-w-2xl mx-auto leading-relaxed">
        "El amor no tiene fronteras, no conoce género, no entiende de reglas.
        Solo sabe ser auténtico, libre y eterno."
      </blockquote>
      <p class="font-sans text-xs tracking-[0.2em] uppercase text-gold-light/50 mt-6">
        — Andrés &amp; Miguel
      </p>
    </div>

  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) { (e.target as HTMLElement).classList.add("visible"); observer.unobserve(e.target); }
    }),
    { rootMargin: "-50px" }
  );
  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>

<style>
  .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }
</style>
