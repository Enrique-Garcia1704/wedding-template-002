---
---

<section class="py-24 bg-background">
  <div class="max-w-2xl mx-auto px-6">

    <div class="text-center mb-16 reveal">
      <p class="font-sans text-xs tracking-[0.35em] uppercase text-sage mb-4">
        Tu presencia es nuestro mejor regalo
      </p>
      <h2 class="font-serif text-4xl md:text-5xl font-light text-foreground">
        Confirma tu Asistencia
      </h2>
      <div class="ornament-divider text-gold text-sm mt-6 max-w-xs mx-auto">❖</div>
    </div>

    <!-- Form -->
    <form id="rsvp-form" class="space-y-6 reveal" style="transition-delay: 0.3s">
      <div>
        <label class="block font-sans text-xs tracking-[0.2em] uppercase text-muted-foreground mb-2">
          Nombre completo
        </label>
        <input
          type="text"
          name="name"
          required
          class="w-full bg-transparent border-b border-border py-3 font-serif text-lg text-foreground focus:border-gold focus:outline-none transition-colors placeholder:text-muted-foreground/40"
          placeholder="Tu nombre"
        />
      </div>

      <div class="grid grid-cols-2 gap-6">
        <div>
          <label class="block font-sans text-xs tracking-[0.2em] uppercase text-muted-foreground mb-2">
            Asistencia
          </label>
          <select
            name="attending"
            class="w-full bg-transparent border-b border-border py-3 font-serif text-lg text-foreground focus:border-gold focus:outline-none transition-colors"
          >
            <option value="yes">Asistiré con mucho gusto</option>
            <option value="no">Lamentablemente no podré</option>
          </select>
        </div>

        <div>
          <label class="block font-sans text-xs tracking-[0.2em] uppercase text-muted-foreground mb-2">
            Acompañantes
          </label>
          <select
            name="guests"
            class="w-full bg-transparent border-b border-border py-3 font-serif text-lg text-foreground focus:border-gold focus:outline-none transition-colors"
          >
            <option value="1">Solo yo</option>
            <option value="2">+1 acompañante</option>
            <option value="3">+2 acompañantes</option>
          </select>
        </div>
      </div>

      <div>
        <label class="block font-sans text-xs tracking-[0.2em] uppercase text-muted-foreground mb-2">
          Un mensaje para los novios
        </label>
        <textarea
          name="message"
          rows={3}
          class="w-full bg-transparent border-b border-border py-3 font-serif text-lg text-foreground focus:border-gold focus:outline-none transition-colors resize-none placeholder:text-muted-foreground/40"
          placeholder="Escríbenos algo bonito..."
        />
      </div>

      <button
        type="submit"
        class="w-full mt-8 py-4 border-2 border-gold font-sans text-xs tracking-[0.3em] uppercase text-gold hover:bg-accent hover:text-accent-foreground transition-all duration-500 hover:scale-[1.02] active:scale-[0.98]"
      >
        Confirmar asistencia
      </button>
    </form>

    <!-- Thank you message (hidden by default) -->
    <div id="rsvp-thanks" class="hidden text-center py-16">
      <div class="text-5xl mb-6">🤍</div>
      <h3 id="thanks-name" class="font-serif text-3xl text-foreground mb-4"></h3>
      <p id="thanks-msg" class="font-sans text-muted-foreground"></p>
    </div>

  </div>
</section>

<script>
  const form   = document.getElementById("rsvp-form") as HTMLFormElement;
  const thanks = document.getElementById("rsvp-thanks")!;

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name      = data.get("name") as string;
    const attending = data.get("attending") as string;

    document.getElementById("thanks-name")!.textContent = `¡Gracias, ${name}!`;
    document.getElementById("thanks-msg")!.textContent = attending === "yes"
      ? "Estamos muy emocionados de que nos acompañes en este día tan especial. ¡Nos vemos pronto!"
      : "Lamentamos que no puedas acompañarnos, pero te llevamos en el corazón.";

    form.classList.add("hidden");
    thanks.classList.remove("hidden");
    thanks.classList.add("fade-in");
  });

  // reveal on scroll
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) { (e.target as HTMLElement).classList.add("visible"); observer.unobserve(e.target); }
    }),
    { rootMargin: "-50px" }
  );
  document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
</script>

<style>
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }
  .fade-in { animation: fadeIn 0.6s ease forwards; }
  @keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
</style>
